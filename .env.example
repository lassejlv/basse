# Local development defaults.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/basse
REDIS_URL=redis://127.0.0.1:6379
BETTER_AUTH_SECRET=change-me-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000
WEB_ORIGIN=http://localhost:5173
API_ORIGIN=http://localhost:3000
BASSE_PUBLIC_URL=http://localhost:5173
API_PORT=3000
API_HOST=127.0.0.1

# Docker Compose self-hosting. For a real server, copy this file to `.env`,
# generate BETTER_AUTH_SECRET with `openssl rand -base64 32`, then set:
# DOMAIN=example.com
# BASSE_PUBLIC_URL=https://example.com
# WEB_ORIGIN=https://example.com
# API_ORIGIN=https://example.com
DOMAIN=localhost
BASSE_DATA_DIR=/data/basse
# Keep this false for first self-host bootstrap without SMTP. Set true after
# SMTP is configured if you want verified signups.
EMAIL_VERIFICATION=false
HTTP_PORT=80
HTTPS_PORT=443
CONTROL_PLANE_IMAGE=ghcr.io/lassejlv/basse-control-plane:latest
INSTALL_SCRIPT_URL=https://raw.githubusercontent.com/lassejlv/basse/main/install.sh
UPDATE_SCRIPT_URL=https://raw.githubusercontent.com/lassejlv/basse/main/update.sh
POSTGRES_DB=basse
POSTGRES_USER=basse
POSTGRES_PASSWORD=basse

# GitHub App integration (private repo deploys + push webhooks).
# WEB_ORIGIN: public URL of the web UI — used for the App setup/callback URLs
# and for CORS + Better Auth trusted origins in production.
# API_ORIGIN: public HTTPS URL of the API — used for the GitHub webhook URL so
# GitHub can reach it. Set this to your tunnel URL when testing locally.
# Optional display-name prefix for generated GitHub Apps (defaults to "Basse").
GITHUB_APP_NAME=

# Agent image the control plane runs on user servers during provisioning.
BASSE_AGENT_IMAGE=ghcr.io/lassejlv/basse-agent:latest
# Shared secret for the bundled self-host local agent. The install script
# generates this automatically.
BASSE_LOCAL_AGENT_TOKEN=change-me-local-agent-token

# Background job queue (BullMQ). Locally: `brew services start redis`.
QUEUE_CONCURRENCY=5

# Optional email delivery for OTPs, alerts, and deployment notifications.
# Leave SMTP_HOST empty to run without outgoing emails. Alert creation still works.
EMAIL_FROM="Basse <alerts@example.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
SMTP_ALLOW_INSECURE_AUTH=false
SMTP_AUTH_METHOD=plain
SMTP_USER=
SMTP_PASSWORD=
