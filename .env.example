DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/basse
BETTER_AUTH_SECRET=change-me-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000
API_PORT=3000
API_HOST=127.0.0.1
BASSE_PUBLIC_URL=http://localhost:5173

DOMAIN=basse.sh
CONTROL_PLANE_IMAGE=ghcr.io/lassejlv/basse-control-plane:latest

# GitHub App integration (private repo deploys + push webhooks).
# WEB_ORIGIN: public URL of the web UI — used for the App setup/callback URLs
# and for CORS + Better Auth trusted origins in production.
WEB_ORIGIN=
# API_ORIGIN: public HTTPS URL of the API — used for the GitHub webhook URL so
# GitHub can reach it. Set this to your tunnel URL when testing locally.
API_ORIGIN=
# Optional display-name prefix for generated GitHub Apps (defaults to "Basse").
GITHUB_APP_NAME=

# Agent image the control plane runs on user servers during provisioning.
BASSE_AGENT_IMAGE=ghcr.io/lassejlv/basse-agent:latest

# Background job queue (BullMQ). Locally: `brew services start redis`.
REDIS_URL=redis://127.0.0.1:6379
QUEUE_CONCURRENCY=5

# Optional alert email delivery via @opencoredev/email-sdk's Cloudflare adapter.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# Optional override if you keep a separate token for email sending.
CLOUDFLARE_EMAIL_API_TOKEN=
EMAIL_FROM="Basse <alerts@example.com>"
